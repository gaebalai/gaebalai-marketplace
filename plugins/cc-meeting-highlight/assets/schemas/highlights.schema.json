{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaebalai.dev/cc-meeting-highlight/highlights.schema.json",
  "title": "Highlight60 Composition Props",
  "type": "object",
  "required": ["totalDurationSec", "fps", "clips"],
  "properties": {
    "title": { "type": "string" },
    "meeting_date": { "type": "string", "pattern": "^\\d{4}_\\d{2}_\\d{2}$" },
    "totalDurationSec": { "type": "number", "minimum": 1 },
    "fps": { "type": "integer", "enum": [24, 25, 30, 60] },
    "clips": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "src", "caption", "sourceStartSec", "sourceEndSec", "durationSec"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "src": { "type": "string", "pattern": "^clips/clip_\\d+\\.mp4$" },
          "topic": { "type": "string" },
          "caption": { "type": "string", "maxLength": 30, "description": "메인 자막. 한국어 권장 18자, 절대 한도 30자" },
          "subCaption": { "type": "string", "maxLength": 50, "description": "보조 자막. 한국어 권장 35자, 절대 한도 50자" },
          "sourceStartSec": { "type": "number", "minimum": 0 },
          "sourceEndSec": { "type": "number", "minimum": 0 },
          "durationSec": { "type": "number", "minimum": 1 },
          "speakers": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
