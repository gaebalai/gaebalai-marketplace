{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaebalai.dev/cc-meeting-highlight/topics.schema.json",
  "title": "Meeting Topics",
  "type": "object",
  "required": ["topics"],
  "properties": {
    "meeting_date": { "type": "string", "pattern": "^\\d{4}_\\d{2}_\\d{2}$" },
    "totalDurationSec": { "type": "number", "minimum": 0 },
    "topics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "title", "summary", "startSec", "endSec"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "startSec": { "type": "number", "minimum": 0 },
          "endSec": { "type": "number", "minimum": 0 },
          "anchorTexts": { "type": "array", "items": { "type": "string" } },
          "speakers": { "type": "array", "items": { "type": "string" } },
          "importance": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
